# Mautic API
MAUTIC_BASE_URL=https://mautic.dynamixsolutions.org
MAUTIC_USERNAME=admin
MAUTIC_PASSWORD=replace-me

# App password (single password for the upload form)
UPLOAD_PASSWORD=replace-me

# Iron-session secret — must be a random string of at least 32 chars
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_PASSWORD=replace-me-with-32-random-bytes-hex

# Tag to apply to imported contacts (must match what Vultr's marketing-emails service expects)
LEAD_TAG=lead bites
